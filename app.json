{
  "expo": {
    "name": "OnlyKrida",
    "slug": "onlysports-vd08a76",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "onlykrida",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0f1a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.onlykrida.app",
      "infoPlist": {
        "UIBackgroundModes": ["audio", "remote-notification"],
        "NSPhotoLibraryUsageDescription": "OnlyKrida uses your photos so you can add highlights and images to your athlete portfolio.",
        "NSCameraUsageDescription": "OnlyKrida uses your camera to record fitness-test videos and highlights for your portfolio.",
        "NSMicrophoneUsageDescription": "OnlyKrida uses your microphone to record audio with your highlight and fitness-test videos.",
        "NSMotionUsageDescription": "OnlyKrida uses motion sensors to measure your performance during in-app fitness tests."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0a0f1a"
      },
      "package": "com.onlykrida.app",
      "manifest": {
        "android:supportsPictureInPicture": true
      },
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "INTERNET",
        "HIGH_SAMPLING_RATE_SENSORS",
        "VIBRATE",
        "POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://onlykrida.app/"
        }
      ],
      [
        "expo-video",
        {
          "supportsBackgroundPlayback": true,
          "supportsPictureInPicture": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you share them with your friends."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#1a8cff",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
