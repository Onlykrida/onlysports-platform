# Environment Variables Template
# Copy this file to .env and fill in your actual Supabase credentials

# Supabase Configuration
# Get these from your Supabase project dashboard > Settings > API
EXPO_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Service role key — used ONLY by scripts/ (seed, nuke-and-seed). NEVER prefix
# with EXPO_PUBLIC_ (that inlines it into the shipped bundle). Not required to
# run the app.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# NOTE: There is intentionally NO Anthropic API key here. All Claude calls go
# through the claude-proxy Supabase Edge Function, which holds the key as a
# server-side secret. Do NOT add EXPO_PUBLIC_ANTHROPIC_API_KEY — EXPO_PUBLIC_*
# vars are inlined into the JS bundle and extractable from any shipped binary.

# Example:
# EXPO_PUBLIC_SUPABASE_URL=https://abcdefghijklmnop.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...