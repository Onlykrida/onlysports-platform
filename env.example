# Supabase Configuration
# Get these from: https://supabase.com/dashboard → Your Project → Settings → API

# Required for basic app functionality
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Required ONLY for mock data generation (bypasses RLS)
# ⚠️ WARNING: Never expose this key in production or commit it to git!
EXPO_PUBLIC_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
